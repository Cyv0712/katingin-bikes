PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/jettlaudonedeal
CORS_ORIGIN=http://localhost:5173

# Optional: omit these to keep storing uploads in backend/uploads/
# Either set CLOUDINARY_URL (Dashboard → API Environment variable), or all three:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=jett-lau-done-deal/bikes

# Admin Credentials (highly recommended to use ADMIN_PASSWORD_HASH)
# Run `npm run generate-hash` to generate a secure bcrypt hash of your password
ADMIN_PASSWORD_HASH=your_secure_bcrypt_hash
# Optional legacy plaintext fallback (not recommended for production):
# ADMIN_PASSWORD=your_secure_password

# JWT Secret Key (required for production). Use a strong random value.
JWT_SECRET=your_secure_jwt_secret_key

# SMTP Configuration (Automated Email Inquiry Notification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=katingin.bikes@gmail.com
SMTP_PASS=your_gmail_app_password
INQUIRY_RECEIVER_EMAIL=katingin.bikes@gmail.com

